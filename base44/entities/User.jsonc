{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "manager",
        "staff"
      ],
      "default": "staff",
      "description": "User role: admin = full access, manager = operations access, staff = recipes & menu only"
    }
  }
}